<Window x:Class="Listly.Views.M2CommanderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="clr-namespace:Listly.Behaviors"
        xmlns:a="clr-namespace:Listly.Assets"
        Title="M2 Commander"
        Width="1040"
        Height="660"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{DynamicResource ThemeSolidBackgroundBrush}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- Function-key bar button -->
        <Style x:Key="FnButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="8,6" Margin="1,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1" />
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Panes: 2-4 equal-width panes rebuilt at runtime, with a + to add one -->
        <Grid Grid.Row="0" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="PaneHost" Grid.Column="0" />

            <Button x:Name="AddPaneButton"
                    Grid.Column="1"
                    Style="{StaticResource FnButtonStyle}"
                    Width="30"
                    Margin="4,0,0,0"
                    VerticalAlignment="Stretch"
                    Click="OnAddPaneClick"
                    ToolTip="{b:Loc commander.addPane}">
                <TextBlock Text="+" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource ThemeAccentBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
        </Grid>

        <!-- Status line -->
        <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" Margin="8,0">
            <TextBlock x:Name="StatusText"
                       Margin="12,5"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource ThemeSubtleBrush}" />
        </Border>

        <!-- Function-key bar + custom command strip (below the file grid) -->
        <Border Grid.Row="2" Background="{DynamicResource ThemeSolidBackgroundBrush}" Padding="6,6,6,8">
            <StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="ActionsButton" Style="{StaticResource FnButtonStyle}" Click="OnActionsClick">
                            <TextBlock><Run Text="F1 " Foreground="{DynamicResource ThemeAccentBrush}" FontWeight="Bold" /><Run Text="{b:Loc commander.actions}" Foreground="{DynamicResource ThemeTextBrush}" /></TextBlock>
                        </Button>
                        <Button x:Name="CommandsButton" Style="{StaticResource FnButtonStyle}" Click="OnCommandsClick">
                            <TextBlock><Run Text="F11 " Foreground="{DynamicResource ThemeAccentBrush}" FontWeight="Bold" /><Run Text="{b:Loc commander.commands}" Foreground="{DynamicResource ThemeTextBrush}" /></TextBlock>
                        </Button>
                        <Button x:Name="HelpButton" Style="{StaticResource FnButtonStyle}" Click="OnHelpClick">
                            <TextBlock><Run Text="F12 " Foreground="{DynamicResource ThemeAccentBrush}" FontWeight="Bold" /><Run Text="{b:Loc commander.help}" Foreground="{DynamicResource ThemeTextBrush}" /></TextBlock>
                        </Button>
                        <Button x:Name="QuitButton" Style="{StaticResource FnButtonStyle}" Click="OnQuitClick">
                            <TextBlock><Run Text="F10 " Foreground="{DynamicResource ThemeAccentBrush}" FontWeight="Bold" /><Run Text="{b:Loc commander.quit}" Foreground="{DynamicResource ThemeTextBrush}" /></TextBlock>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Path Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                              Data="{x:Static a:M2Logo.Geometry}"
                              Fill="{DynamicResource ThemeAccentBrush}" />
                        <TextBlock x:Name="BrandText" Text="M2 Commander" Margin="7,0,0,0" VerticalAlignment="Center"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeTextBrush}" />
                    </StackPanel>
                </Grid>

                <!-- User-defined launcher buttons (configured with F11) -->
                <ItemsControl x:Name="CommandBar" Margin="1,4,1,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource FnButtonStyle}" Tag="{Binding}" Click="OnCommandButtonClick">
                                <TextBlock><Run Text="&#x25B8; " Foreground="{DynamicResource ThemeAccentBrush}" FontWeight="Bold" /><Run Text="{Binding Label}" Foreground="{DynamicResource ThemeTextBrush}" /></TextBlock>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Modal prompt overlay (MkDir / Rename) -->
        <Grid x:Name="PromptOverlay"
              Grid.RowSpan="3"
              Background="#99000000"
              Visibility="Collapsed">
            <Border Width="420"
                    Background="{DynamicResource ThemeCardBrush}"
                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000" />
                </Border.Effect>
                <StackPanel Margin="18">
                    <TextBlock x:Name="PromptTitle"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource ThemeTextBrush}" />
                    <TextBox x:Name="PromptBox"
                             FontSize="14"
                             Padding="8,6"
                             Background="{DynamicResource ThemeInputBrush}"
                             Foreground="{DynamicResource ThemeTextBrush}"
                             CaretBrush="{DynamicResource ThemeAccentBrush}"
                             BorderBrush="{DynamicResource ThemeBorderBrush}"
                             BorderThickness="1"
                             KeyDown="OnPromptKeyDown" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{b:Loc commander.ok}" MinWidth="88" Padding="10,6" Margin="0,0,8,0" Click="OnPromptOkClick" />
                        <Button Content="{b:Loc commander.cancel}" MinWidth="88" Padding="10,6" Click="OnPromptCancelClick" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Help overlay (F12): every keyboard shortcut -->
        <Grid x:Name="HelpOverlay"
              Grid.RowSpan="3"
              Background="#99000000"
              Visibility="Collapsed">
            <Border Width="600"
                    MaxHeight="600"
                    Background="{DynamicResource ThemeCardBrush}"
                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000" />
                </Border.Effect>
                <DockPanel Margin="20">
                    <TextBlock DockPanel.Dock="Top"
                               Text="{b:Loc commander.shortcuts}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"
                               Foreground="{DynamicResource ThemeTextBrush}" />
                    <Button DockPanel.Dock="Bottom"
                            x:Name="HelpCloseButton"
                            Content="{b:Loc commander.ok}"
                            MinWidth="96"
                            Padding="10,6"
                            HorizontalAlignment="Right"
                            Margin="0,14,0,0"
                            Click="OnHelpCloseClick" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HelpList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="156" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Keys}"
                                                   FontFamily="Consolas"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ThemeAccentBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Desc}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource ThemeTextBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Custom command editor overlay (F11) -->
        <Grid x:Name="CommandEditorOverlay"
              Grid.RowSpan="3"
              Background="#99000000"
              Visibility="Collapsed">
            <Border Width="740"
                    MaxHeight="580"
                    Background="{DynamicResource ThemeCardBrush}"
                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000" />
                </Border.Effect>
                <DockPanel Margin="20">
                    <TextBlock DockPanel.Dock="Top"
                               Text="{b:Loc commander.cmd.title}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextBrush}" />
                    <TextBlock DockPanel.Dock="Top"
                               Text="{b:Loc commander.cmd.hint}"
                               FontSize="11.5"
                               TextWrapping="Wrap"
                               Margin="0,4,0,12"
                               Foreground="{DynamicResource ThemeSubtleBrush}" />

                    <CheckBox DockPanel.Dock="Top"
                              x:Name="ForceEnglishCheck"
                              Content="{b:Loc commander.cmd.forceEnglish}"
                              FontSize="12.5"
                              Margin="0,0,0,12"
                              Foreground="{DynamicResource ThemeTextBrush}" />

                    <CheckBox DockPanel.Dock="Top"
                              x:Name="KeepFilterCheck"
                              Content="{b:Loc commander.cmd.keepFilter}"
                              FontSize="12.5"
                              Margin="0,0,0,12"
                              Foreground="{DynamicResource ThemeTextBrush}" />

                    <!-- Auto detect: fills M2_ST4 / M2_LOG / VS Code program paths from the index -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AutoDetectButton"
                                    Content="{b:Loc commander.cmd.autoDetect}"
                                    MinWidth="140"
                                    Padding="10,6"
                                    Click="OnCommandAutoDetectClick" />
                            <TextBlock x:Name="AutoDetectResult"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource ThemeSubtleBrush}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock DockPanel.Dock="Top"
                               Text="{b:Loc commander.cmd.section}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,4,0,6"
                               Foreground="{DynamicResource ThemeTextBrush}" />

                    <!-- Action buttons -->
                    <Grid DockPanel.Dock="Bottom" Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{b:Loc commander.ok}" MinWidth="96" Padding="10,6" Margin="0,0,8,0" Click="OnCommandSaveClick" />
                            <Button Content="{b:Loc commander.cancel}" MinWidth="96" Padding="10,6" Click="OnCommandCancelClick" />
                        </StackPanel>
                    </Grid>

                    <!-- Column headers -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{b:Loc commander.cmd.label}" FontSize="11" Foreground="{DynamicResource ThemeSubtleBrush}" />
                        <TextBlock Grid.Column="1" Text="{b:Loc commander.cmd.program}" FontSize="11" Margin="6,0,0,0" Foreground="{DynamicResource ThemeSubtleBrush}" />
                        <TextBlock Grid.Column="3" Text="{b:Loc commander.cmd.args}" FontSize="11" Margin="6,0,0,0" Foreground="{DynamicResource ThemeSubtleBrush}" />
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                        <ItemsControl x:Name="CommandEditorList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4"
                                                 VerticalContentAlignment="Center"
                                                 Background="{DynamicResource ThemeInputBrush}"
                                                 Foreground="{DynamicResource ThemeTextBrush}"
                                                 CaretBrush="{DynamicResource ThemeAccentBrush}"
                                                 BorderBrush="{DynamicResource ThemeBorderBrush}"
                                                 BorderThickness="1" />
                                        <TextBox Grid.Column="1"
                                                 Margin="6,0,0,0"
                                                 Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4"
                                                 VerticalContentAlignment="Center"
                                                 Background="{DynamicResource ThemeInputBrush}"
                                                 Foreground="{DynamicResource ThemeTextBrush}"
                                                 CaretBrush="{DynamicResource ThemeAccentBrush}"
                                                 BorderBrush="{DynamicResource ThemeBorderBrush}"
                                                 BorderThickness="1" />
                                        <Button Grid.Column="2"
                                                Margin="4,0,0,0"
                                                Content="&#x2026;"
                                                Tag="{Binding}"
                                                ToolTip="{b:Loc commander.cmd.program}"
                                                Click="OnCommandBrowseClick" />
                                        <TextBox Grid.Column="3"
                                                 Margin="6,0,0,0"
                                                 Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4"
                                                 FontFamily="Consolas"
                                                 VerticalContentAlignment="Center"
                                                 Background="{DynamicResource ThemeInputBrush}"
                                                 Foreground="{DynamicResource ThemeTextBrush}"
                                                 CaretBrush="{DynamicResource ThemeAccentBrush}"
                                                 BorderBrush="{DynamicResource ThemeBorderBrush}"
                                                 BorderThickness="1" />
                                        <Button Grid.Column="4"
                                                Margin="4,0,0,0"
                                                Content="&#x2715;"
                                                Tag="{Binding}"
                                                Click="OnCommandRemoveClick" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="{b:Loc commander.cmd.add}" HorizontalAlignment="Left" MinWidth="120" Padding="10,6" Margin="0,8,0,0" Click="OnCommandAddClick" />

                        <!-- Quick links (shown on the drives / This-PC view) -->
                        <TextBlock Text="{b:Loc commander.links.section}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,16,0,6"
                                   Foreground="{DynamicResource ThemeTextBrush}" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="98" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{b:Loc commander.links.name}" FontSize="11" Foreground="{DynamicResource ThemeSubtleBrush}" />
                            <TextBlock Grid.Column="1" Text="{b:Loc commander.links.target}" FontSize="11" Margin="6,0,0,0" Foreground="{DynamicResource ThemeSubtleBrush}" />
                        </Grid>
                        <ItemsControl x:Name="LinkEditorList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="30" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4" VerticalContentAlignment="Center"
                                                 Background="{DynamicResource ThemeInputBrush}" Foreground="{DynamicResource ThemeTextBrush}"
                                                 CaretBrush="{DynamicResource ThemeAccentBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" />
                                        <TextBox Grid.Column="1" Margin="6,0,0,0"
                                                 Text="{Binding Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4" VerticalContentAlignment="Center"
                                                 Background="{DynamicResource ThemeInputBrush}" Foreground="{DynamicResource ThemeTextBrush}"
                                                 CaretBrush="{DynamicResource ThemeAccentBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" />
                                        <Button Grid.Column="2" Margin="4,0,0,0" Content="&#x2191;" Tag="{Binding}" ToolTip="{b:Loc commander.links.up}" Click="OnLinkUpClick" />
                                        <Button Grid.Column="3" Margin="4,0,0,0" Content="&#x2193;" Tag="{Binding}" ToolTip="{b:Loc commander.links.down}" Click="OnLinkDownClick" />
                                        <Button Grid.Column="4" Margin="4,0,0,0" Content="&#x2715;" Tag="{Binding}" Click="OnLinkRemoveClick" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="{b:Loc commander.links.add}" HorizontalAlignment="Left" MinWidth="120" Padding="10,6" Margin="0,8,0,0" Click="OnLinkAddClick" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
