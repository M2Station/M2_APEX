<Window x:Class="Listly.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="clr-namespace:Listly.Behaviors"
        Title="M2_APEX"
        Width="720"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.Resources>
        <b:KindToLabelConverter x:Key="KindToLabel" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Background="Transparent"
                                Padding="10,7"
                                Margin="8,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="18"
            CornerRadius="14"
            Background="{DynamicResource ThemeCardBrush}"
            BorderBrush="{DynamicResource ThemeBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search box -->
            <Grid Grid.Row="0" Margin="18,14,18,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="{DynamicResource M2LogoImage}"
                       Width="24"
                       Height="24"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Stretch="Uniform" />

                <Grid Grid.Column="1">
                    <TextBlock Text="{b:Loc search.placeholder}"
                               VerticalAlignment="Center"
                               FontSize="20"
                               Foreground="{DynamicResource ThemeSubtleBrush}"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=QueryBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBox x:Name="QueryBox"
                             Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource ThemeTextBrush}"
                             CaretBrush="{DynamicResource ThemeAccentBrush}"
                             FontSize="20"
                             VerticalContentAlignment="Center"
                             Padding="0"
                             SelectionBrush="{DynamicResource ThemeAccentBrush}" />
                </Grid>
            </Grid>

            <!-- Separator (only when there are results) -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource ThemeSeparatorBrush}"
                    Visibility="{Binding HasItems, ElementName=ResultsList, Converter={StaticResource BoolToVis}}" />

            <!-- Results -->
            <ListBox x:Name="ResultsList"
                     Grid.Row="2"
                     ItemsSource="{Binding Results}"
                     SelectedIndex="{Binding SelectedIndex}"
                     Background="Transparent"
                     BorderThickness="0"
                     MaxHeight="460"
                     Focusable="False"
                     Padding="0,6"
                     ItemContainerStyle="{StaticResource ResultItemStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="{Binding Glyph}"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeAccentBrush}" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock b:Highlight.Result="{Binding}"
                                           FontSize="15"
                                           Foreground="{DynamicResource ThemeTextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Subtitle}"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource ThemeSubtleBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,1,0,0" />
                            </StackPanel>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Kind, Converter={StaticResource KindToLabel}}"
                                       FontSize="10.5"
                                       VerticalAlignment="Center"
                                       Margin="10,0,4,0"
                                       Foreground="{DynamicResource ThemeSubtleBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Status / hint bar -->
            <Border Grid.Row="3"
                    Background="#14000000"
                    CornerRadius="0,0,14,14">
                <Grid Margin="16,7">
                    <TextBlock Text="{Binding Status}"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeSubtleBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock HorizontalAlignment="Right"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeSubtleBrush}"
                               Text="{b:Loc search.hint}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
