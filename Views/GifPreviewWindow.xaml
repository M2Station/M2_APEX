<Window x:Class="Listly.Views.GifPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="clr-namespace:Listly.Behaviors"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Topmost="True"
        FontFamily="Segoe UI"
        MouseLeftButtonUp="OnBackdropClick">

    <Border Background="{DynamicResource ThemeCardBrush}"
            BorderBrush="{DynamicResource ThemeBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <Grid Grid.Row="0" Margin="18,14,10,10">
                <TextBlock VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource ThemeTextBrush}">
                    <Run Text="Ctrl+`" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentBrush}" /><Run Text="  —  M2 Commander" FontWeight="SemiBold" />
                </TextBlock>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="&#x2715;"
                        FontSize="13"
                        Padding="8,3"
                        Cursor="Hand"
                        Foreground="{DynamicResource ThemeSubtleBrush}"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnCloseClick" />
            </Grid>

            <!-- Animated GIF -->
            <Border Grid.Row="1"
                    Margin="18,0,18,10"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Background="#22000000">
                <Image x:Name="GifImage"
                       Width="880"
                       Height="440"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Border>

            <!-- Footer hint -->
            <TextBlock Grid.Row="2"
                       Margin="18,0,18,14"
                       HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource ThemeSubtleBrush}"
                       Text="{b:Loc search.gifClose}" />
        </Grid>
    </Border>
</Window>
