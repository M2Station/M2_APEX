<UserControl x:Class="Listly.Views.CommanderPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:Listly.Behaviors"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- One list row: [glyph + name] | size | date -->
        <Style x:Key="CommanderItemStyle" TargetType="ListBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="6,2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CommanderRowTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="132" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="{Binding Glyph}"
                               FontSize="14"
                               Width="22"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ThemeAccentBrush}" />
                    <TextBlock x:Name="NameText"
                               b:Highlight.MatchText="{Binding Name}"
                               b:Highlight.MatchIndices="{Binding MatchedIndices}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource ThemeTextBrush}" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding SizeText}"
                           FontFamily="Consolas"
                           FontSize="12.5"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{DynamicResource ThemeSubtleBrush}" />

                <TextBlock Grid.Column="2"
                           Text="{Binding DateText}"
                           FontFamily="Consolas"
                           FontSize="12.5"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeSubtleBrush}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="NameText" Property="FontWeight" Value="SemiBold" />
                    <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource ThemeAccentBrush}" />
                    <!-- Folder names are accent-coloured, so render filter matches as an inverted block. -->
                    <Setter TargetName="NameText" Property="b:Highlight.BlockMode" Value="True" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Pane header close (×) button -->
        <Style x:Key="PaneCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="9,2" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeSubtleBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="0,5,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeButtonHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="Root"
            BorderBrush="{DynamicResource ThemeBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Background="{DynamicResource ThemePanelBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderBar"
                    Grid.Row="0"
                    Background="{DynamicResource ThemeButtonBrush}"
                    CornerRadius="5,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PathText"
                               Grid.Column="0"
                               Text="…"
                               Margin="10,6"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ThemeTextBrush}" />
                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Style="{StaticResource PaneCloseButtonStyle}"
                            Content="&#x2715;"
                            Visibility="Collapsed"
                            ToolTip="{b:Loc commander.closePane}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="6,4,6,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="132" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{b:Loc commander.colName}" FontSize="11" Foreground="{DynamicResource ThemeSubtleBrush}" />
                <TextBlock Grid.Column="1" Text="{b:Loc commander.colSize}" FontSize="11" HorizontalAlignment="Right" Margin="0,0,10,0" Foreground="{DynamicResource ThemeSubtleBrush}" />
                <TextBlock Grid.Column="2" Text="{b:Loc commander.colDate}" FontSize="11" Foreground="{DynamicResource ThemeSubtleBrush}" />
            </Grid>

            <ListBox x:Name="List"
                     Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="2,2,2,6"
                     ItemContainerStyle="{StaticResource CommanderItemStyle}"
                     ItemTemplate="{StaticResource CommanderRowTemplate}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch" />
        </Grid>
    </Border>
</UserControl>
