<Window x:Class="Listly.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="M2_APEX Settings"
        Width="540"
        Height="660"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E14"
        FontFamily="Segoe UI"
        Foreground="#CFE3F2">

    <Window.Resources>
        <SolidColorBrush x:Key="Subtle" Color="#8AA0B6" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFE3F2" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CFE3F2" />
            <Setter Property="Margin" Value="0,7" />
        </Style>
        <Style x:Key="Header" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#36D6FF" />
            <Setter Property="Margin" Value="0,18,0,6" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0E1622" />
            <Setter Property="Foreground" Value="#CFE3F2" />
            <Setter Property="BorderBrush" Value="#2A3A4D" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CaretBrush" Value="#36D6FF" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Activation" Style="{StaticResource Header}" Margin="0,0,0,6" />
                <CheckBox x:Name="DoubleCtrlBox" Content="Show search bar on double-tap Ctrl" />
                <CheckBox x:Name="AltSpaceBox" Content="Show search bar on Alt+Space" />
                <CheckBox x:Name="QuickSwitchBox" Content="Quick Switch: type in File Explorer to jump to a file" />
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="Double-Ctrl max gap (ms):" VerticalAlignment="Center" />
                    <TextBox x:Name="ThresholdBox" Width="70" Margin="10,0,0,0" />
                </StackPanel>

                <TextBlock Text="Results" Style="{StaticResource Header}" />
                <CheckBox x:Name="FilesFirstBox" Content="Prioritise files and folders over apps" />
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="Maximum results:" VerticalAlignment="Center" />
                    <TextBox x:Name="MaxResultsBox" Width="70" Margin="10,0,0,0" />
                </StackPanel>
                <TextBlock Text="Web search URL ({0} = query):" Margin="0,8,0,4" Foreground="{StaticResource Subtle}" />
                <TextBox x:Name="WebUrlBox" />

                <TextBlock Text="Indexing" Style="{StaticResource Header}" />
                <CheckBox x:Name="HiddenBox" Content="Include hidden files" />
                <TextBlock Text="Indexed drives (one per line, blank = all fixed drives):"
                           Margin="0,8,0,4" Foreground="{StaticResource Subtle}" />
                <TextBox x:Name="DrivesBox" Height="60" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" />
                <TextBlock Text="Excluded folder names (one per line):"
                           Margin="0,10,0,4" Foreground="{StaticResource Subtle}" />
                <TextBox x:Name="ExcludedBox" Height="120" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" />

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <Button x:Name="RebuildButton" Content="Rebuild index now" Padding="12,6" Click="OnRebuildClick" />
                    <TextBlock x:Name="IndexStatus" VerticalAlignment="Center" Margin="14,0,0,0"
                               Foreground="{StaticResource Subtle}" />
                </StackPanel>

                <TextBlock Text="Startup" Style="{StaticResource Header}" />
                <CheckBox x:Name="StartupBox" Content="Launch Listly when Windows starts" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="90" Height="32" Margin="0,0,10,0" Click="OnSaveClick" />
            <Button Content="Close" Width="90" Height="32" Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
